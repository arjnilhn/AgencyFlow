@model AgencyFlow.ViewModels.EarningsViewModel
@{
    ViewData["Title"] = "Earnings";
}

<!-- Summary Row -->
<div class="row mb-4">
    <div class="col-xl-4 col-md-6 mb-4">
        <div class="card border-start border-4 border-success shadow h-100 py-2">
            <div class="card-body">
                <div class="row no-gutters align-items-center">
                    <div class="col mr-2">
                        <div class="text-xs fw-bold text-success text-uppercase mb-1">Total Earnings (All Time)</div>
                        @if (Model?.Summary?.TotalEarningsAllTimeByCurrency.Any() == true)
                        {
                            foreach (var item in Model.Summary.TotalEarningsAllTimeByCurrency)
                            {
                                <div class="h5 mb-0 fw-bold text-gray-800">@item.Key @item.Value</div>
                            }
                        }
                        else
                        {
                            <div class="h5 mb-0 fw-bold text-gray-800">$0</div>
                        }
                    </div>
                    <div class="col-auto"><i class="bi bi-piggy-bank fs-2 text-muted"></i></div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-xl-4 col-md-6 mb-4">
        <div class="card border-start border-4 border-primary shadow h-100 py-2">
            <div class="card-body">
                <div class="row no-gutters align-items-center">
                    <div class="col mr-2">
                        <div class="text-xs fw-bold text-primary text-uppercase mb-1">This Month</div>
                        @if (Model?.Summary?.EarningsThisMonthByCurrency.Any() == true)
                        {
                            foreach (var item in Model.Summary.EarningsThisMonthByCurrency)
                            {
                                <div class="h5 mb-0 fw-bold text-gray-800">@item.Key @item.Value</div>
                            }
                        }
                        else
                        {
                            <div class="h5 mb-0 fw-bold text-gray-800">$0</div>
                        }
                    </div>
                    <div class="col-auto"><i class="bi bi-calendar2-check fs-2 text-muted"></i></div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-xl-4 col-md-6 mb-4">
        <div class="card border-start border-4 border-warning shadow h-100 py-2">
            <div class="card-body">
                <div class="row no-gutters align-items-center">
                    <div class="col mr-2">
                        <div class="text-xs fw-bold text-warning text-uppercase mb-1">Pending Payments</div>
                        @if (Model?.Summary?.PendingPaymentsByCurrency.Any() == true)
                        {
                            foreach (var item in Model.Summary.PendingPaymentsByCurrency)
                            {
                                <div class="h5 mb-0 fw-bold text-gray-800">@item.Key @item.Value</div>
                            }
                        }
                        else
                        {
                            <div class="h5 mb-0 fw-bold text-gray-800">$0</div>
                        }
                    </div>
                    <div class="col-auto"><i class="bi bi-hourglass fs-2 text-muted"></i></div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="row">
    <!-- Chart.js Widget -->
    <div class="col-12 mb-4">
        <div class="card shadow">
            <div class="card-header py-3 d-flex flex-row align-items-center justify-content-between bg-white">
                <h6 class="m-0 fw-bold text-primary">Monthly Earnings Trend</h6>
                <form method="get" action="@Url.Action("Index", "Earnings")" class="d-inline-flex align-items-center m-0">
                    <label class="me-2 fw-bold text-gray-800 small mb-0">Year:</label>
                    <select name="year" class="form-select form-select-sm" onchange="this.form.submit()">
                        @foreach (var y in Model?.AvailableYears ?? new List<int>())
                        {
                            if (y == Model?.SelectedYear)
                            {
                                <option value="@y" selected>@y</option>
                            }
                            else
                            {
                                <option value="@y">@y</option>
                            }
                        }
                    </select>
                </form>
            </div>
            <div class="card-body">
                <div class="chart-area" style="height: 300px;">
                    <canvas id="earningsBarChart"></canvas>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="row">
    <div class="col-12 mb-4">
        <div class="card shadow">
            <div class="card-header py-3 bg-white">
                <h6 class="m-0 fw-bold text-primary">Earning History</h6>
            </div>
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table table-hover table-bordered" width="100%" cellspacing="0">
                        <thead class="table-light">
                            <tr>
                                <th>Date</th>
                                <th>Event</th>
                                <th>Hours</th>
                                <th>Rate</th>
                                <th>Total</th>
                                <th>Status</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model != null && Model.EarningLogs != null && Model.EarningLogs.Any())
                            {
                                @foreach (var log in Model.EarningLogs)
                                {
                                    <tr>
                                        <td class="align-middle">@log.DateCalculated.ToShortDateString()</td>
                                        <td class="align-middle fw-bold">@log.EventTitle</td>
                                        <td class="align-middle">@log.HoursWorked h</td>
                                        <td class="align-middle">@log.Currency@log.AppliedHourlyRate</td>
                                        <td class="align-middle fw-bold text-success">@log.Currency@log.TotalAmount</td>
                                        <td class="align-middle">
                                            <span class="badge @(log.PaymentStatus == "Paid" ? "bg-success" : "bg-warning")">@log.PaymentStatus</span>
                                        </td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="6" class="text-center py-4 text-muted">No earning records found.</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        var ctx = document.getElementById("earningsBarChart");
        if(ctx) {
            // Get CSS variables for dynamic theme colors
            var style = getComputedStyle(document.body);
            var primary = style.getPropertyValue('--primary-color').trim() || '#1cc88a';
            var primaryHover = style.getPropertyValue('--primary-hover').trim() || '#17a673';

            var datasets = @Html.Raw(Json.Serialize(Model?.MonthlyEarningsChart?.Datasets ?? new List<AgencyFlow.ViewModels.ChartDatasetDto>()));

            var chartDatasets = datasets.map(function(ds, index) {
                // If it's the first dataset, let's use the theme primary color as fallback, else use backend color
                var bgColor = index === 0 ? primary : (ds.borderColor || primary);
                var hoverBgColor = index === 0 ? primaryHover : (ds.borderColor || primaryHover);
                return {
                    label: ds.label,
                    backgroundColor: bgColor,
                    hoverBackgroundColor: hoverBgColor,
                    borderColor: ds.borderColor,
                    data: ds.data,
                    maxBarThickness: 50
                };
            });

            new Chart(ctx, {
                type: 'bar',
                data: {
                    labels: @Html.Raw(Json.Serialize(Model?.MonthlyEarningsChart?.Labels ?? new List<string>())),
                    datasets: chartDatasets,
                },
                options: {
                    maintainAspectRatio: false,
                    scales: {
                        x: { grid: { display: false } },
                        y: { grid: { borderDash: [2, 2] } }
                    },
                    plugins: { legend: { display: true } }
                }
            });
        }
    </script>
}
