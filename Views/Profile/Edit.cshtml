@model AgencyFlow.ViewModels.ProfileEditViewModel
@{
    ViewData["Title"] = "Edit Profile";
}

<div class="row justify-content-center">
    <div class="col-lg-8">
        <div class="card shadow border-0">
            <div class="card-header bg-white py-4 border-0">
                <h5 class="m-0 fw-bold text-primary">Edit Personal Information</h5>
            </div>
            <div class="card-body p-5">
                <form asp-action="Edit" method="post" enctype="multipart/form-data">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-4"></div>

                    <div class="row mb-3">
                        <div class="col-md-6">
                            <div class="form-floating mb-3">
                                <input asp-for="FirstName" class="form-control" placeholder="First Name" />
                                <label asp-for="FirstName"></label>
                                <span asp-validation-for="FirstName" class="text-danger small"></span>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-floating mb-3">
                                <input asp-for="LastName" class="form-control" placeholder="Last Name" />
                                <label asp-for="LastName"></label>
                                <span asp-validation-for="LastName" class="text-danger small"></span>
                            </div>
                        </div>
                    </div>

                    <div class="row mb-3">
                        <div class="col-md-6">
                            <div class="form-floating mb-3">
                                <input asp-for="City" class="form-control" placeholder="City" />
                                <label asp-for="City"></label>
                                <span asp-validation-for="City" class="text-danger small"></span>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-floating mb-3">
                                <input asp-for="DateOfBirth" class="form-control" placeholder="Date of Birth" />
                                <label asp-for="DateOfBirth"></label>
                                <span asp-validation-for="DateOfBirth" class="text-danger small"></span>
                            </div>
                        </div>
                    </div>

                    <div class="mb-4">
                        <label asp-for="ProfilePicture" class="form-label text-muted fw-bold small text-uppercase">Profile Picture Upload</label>
                        <input asp-for="ProfilePicture" class="form-control form-control-lg" type="file" accept="image/*" />
                        <span asp-validation-for="ProfilePicture" class="text-danger small"></span>
                    </div>

                    <hr class="my-4" />

                    <div class="d-flex justify-content-end gap-3">
                        <a href="@Url.Action("Index")" class="btn btn-light px-4">Cancel</a>
                        <button type="submit" class="btn btn-primary px-5 shadow-sm">Save Changes</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
