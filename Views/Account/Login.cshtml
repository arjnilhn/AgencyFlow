@model AgencyFlow.ViewModels.LoginViewModel
@{
    Layout = "_AuthLayout";
    ViewData["Title"] = "Login";
}

<div class="row justify-content-center">
    <div class="col-md-6 col-lg-5">
        <div class="card shadow-lg border-0 rounded-lg mt-5">
            <div class="card-header bg-white text-center py-4">
                <div class="d-flex justify-content-center align-items-center my-2">
                    <img src="~/images/agencyflow_logo.png" alt="AgencyFlow Logo" class="rounded-circle shadow me-2" style="width: 45px; height: 45px; object-fit: cover;" />
                    <h3 class="font-weight-light mb-0 text-primary fw-bold">AgencyFlow</h3>
                </div>
                <p class="text-muted small mb-0">Sign in to your dashboard</p>
            </div>
            <div class="card-body p-5">
                <form asp-action="Login" method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                    <div class="form-floating mb-3">
                        <input asp-for="Email" class="form-control" placeholder="name@example.com" />
                        <label asp-for="Email">Email address</label>
                        <span asp-validation-for="Email" class="text-danger small"></span>
                    </div>
                    <div class="form-floating mb-4">
                        <input asp-for="Password" class="form-control" placeholder="Password" />
                        <label asp-for="Password">Password</label>
                        <span asp-validation-for="Password" class="text-danger small"></span>
                    </div>
                    <div class="form-check mb-3">
                        <input class="form-check-input" asp-for="RememberMe" />
                        <label class="form-check-label text-muted" asp-for="RememberMe">
                            Remember Password
                        </label>
                    </div>
                    <div class="d-grid gap-2 mt-4 mb-0">
                        <button class="btn btn-primary btn-lg" type="submit">Login</button>
                    </div>
                </form>
            </div>
            <div class="card-footer text-center py-3 bg-white">
                <div class="small"><a href="@Url.Action("Register")" class="text-decoration-none">Need an account? Sign up!</a></div>
            </div>
        </div>
    </div>
</div>
